{
  "name": "milliways-smarttests",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node ../scripts/run-mobilewright-with-mcp-env.mjs",
    "build:android": "cd ../android && ./gradlew :app:assembleDebug",
    "test:ios": "node ../scripts/run-mobilewright-with-mcp-env.mjs -- -c mobilewright.config.ts --project=ios",
    "test:android": "npm run build:android && node ../scripts/run-mobilewright-with-mcp-env.mjs -- -c mobilewright.config.ts --project=android",
    "test:smoke": "node ../scripts/run-mobilewright-with-mcp-env.mjs -- mobile/e2e/common/menu.spec.js -c mobilewright.config.ts --project=ios",
    "doctor": "npx mobilewright doctor"
  },
  "dependencies": {
    "@mobilewright/test": "^0.0.37",
    "@testchimp/playwright": "^0.2.3",
    "dotenv": "^16.4.5",
    "mobilewright": "^0.0.37"
  },
  "overrides": {
    "@playwright/test": "1.59.1",
    "playwright": "1.59.1"
  }
}
