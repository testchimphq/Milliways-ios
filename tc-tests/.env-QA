# Environment variables for QA
# One variable per line: KEY=value
# Use in your Playwright scripts via process.env.KEY
# Example:
# BASE_URL=https://qa.example.com
# USERNAME=test_user_qa

# iOS smoke (tc-tests): path to Debug-iphonesimulator .app for Mobilewright installApps
# IOS_APP_PATH=/absolute/path/to/Milliways.app

# TestChimp: Mobilewright project type (also set by `scripts/run-mobilewright-with-mcp-env.mjs`).
TESTCHIMP_PROJECT_TYPE=ios

# TestChimp: `npm test` / `npm run test:smoke` load TESTCHIMP_API_KEY + TESTCHIMP_BACKEND_URL from
# repo `.cursor/mcp.json` via `scripts/run-mobilewright-with-mcp-env.mjs` (staging URL stays in sync with MCP).
# For CI, set secrets / env on the runner instead (no mcp.json there).
# Optional: extra reporter logs
# TESTCHIMP_REPORTER_VERBOSE=1
# Optional: branch context for the dashboard
# TESTCHIMP_BRANCH_NAME=main